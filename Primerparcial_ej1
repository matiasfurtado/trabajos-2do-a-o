# 1. Función recursiva para determinar si Capitán América está en la lista
def buscar_capitan_america(lista):
    # Caso base 1: La lista está vacía, no se encontró
    if len(lista) == 0:
        return False
    
    # Caso base 2: El elemento actual es el Capitán América
    if lista[0] == "Capitán América":
        return True
    
    # Llamada recursiva: achicamos la lista pasando del segundo elemento en adelante
    return buscar_capitan_america(lista[1:])


# 2. Función recursiva para listar (mostrar) los superhéroes
def listar_superheroes(lista):
    # Caso base: Si la lista está vacía, termina la ejecución
    if len(lista) == 0:
        return
    
    print(f"- {lista[0]}")
    
    listar_superheroes(lista[1:])


